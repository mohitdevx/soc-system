# -----------------------------------------------------------------------------
# APP CONFIGURATION
# -----------------------------------------------------------------------------
NODE_ENV="DEVELOPMENT"
PORT=3000

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL / Prisma)
# -----------------------------------------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=""

# -----------------------------------------------------------------------------
# AUTHENTICATION (JWT)
# -----------------------------------------------------------------------------
JWT_SECRET=""
JWT_EXPIRATION="1h"

# -----------------------------------------------------------------------------
# EXTERNAL SERVICES & SECURITY
# -----------------------------------------------------------------------------
CORS_ORIGIN="http://localhost:3000"
REDIS_URL="redis://localhost:6379"
