// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id          String        @id @default(uuid(7))
  name        String        @unique
  email       String        @unique
  password    String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  agentGroups AgentGroup[]
  apiKeys     ApiKey[]
  memberShips MemberShips[]

  @@index([email], name: "idx_organization_email")
  @@map("organizations")
}

enum Role {
  ANALYST
  ADMIN
}

model User {
  id        String   @id @default(uuid(7))
  name      String
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(ANALYST)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberShips MemberShips[]

  @@index([email], name: "idx_user_email")
  @@map("users")
}

enum status {
  PENDING
  ACTIVE
  REJECTED 
  SUSPENDED
}

model MemberShips {
  id             String   @id @default(uuid(7))
  userId         String
  organizationId String
  status        status   @default(PENDING)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([userId], name: "idx_memberships_user_id")
  @@index([organizationId], name: "idx_memberships_organization_id")
  @@map("memberships")
}

model AgentGroup {
  id        String   @id @default(uuid(7))
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  agents         Agent[]
  ApiKeys        ApiKey[]

  @@index([organizationId], name: "idx_agent_group_organization_id")
  @@map("agent_groups")
}

model Agent {
  id          String   @id @default(uuid(7))
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agentGroupId String
  agentGroup   AgentGroup @relation(fields: [agentGroupId], references: [id])

  @@index([agentGroupId], name: "idx_agent_agent_group_id")
  @@map("agents")
}

model ApiKey {
  id             String       @id @default(uuid(7))
  key            String       @unique
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  AgentGroupId   String?
  agentGroup     AgentGroup?  @relation(fields: [AgentGroupId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId], name: "idx_api_key_organization_id")
  @@index([AgentGroupId], name: "idx_api_key_agent_group_id")
  @@map("api_keys")
}

model RawStreams {
  id        String   @id @default(uuid())
  batchId   String
  data      Json
  createdAt DateTime @default(now())

  @@index([batchId], name: "idx_raw_streams_batch_id")
  @@map("raw_streams")
}
